---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MatchesSection from '../components/MatchesSection.astro';
import { stats } from '../../data/stats';
import { sponsors } from '../../data/sponsors';
import { type Match, matches } from '../../data/matches';
import { type Team, teams } from '../../data/teams';

// Obtener los mejores goleadores
const topScorers = stats.topScorers.slice(0, 3);

// Obtener los patrocinadores principales
const mainSponsors = sponsors.filter(s => s.tier === 'platinum' || s.tier === 'gold');

// Obtener los últimos 2 partidos jugados
const lastMatches = matches
  .filter(match => match.status === 'finished')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 2);

// Obtener los próximos 2 partidos
const nextMatches = matches
  .filter(match => match.status === 'scheduled')
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .slice(0, 2);

// Función para obtener equipo por ID
const getTeamById = (teamId: number): Team | undefined => {
  return teams.find(team => team.id === teamId);
};

// Función para obtener nombre del equipo
const getTeamName = (teamId: number): string => {
  return teams.find(team => team.id === teamId)?.name || 'Equipo no encontrado';
};

// Calcular estadísticas para cada equipo
const sortedTeams = teams.map(team => {
  const teamMatches = matches.filter(m =>
    (m.homeTeam === team.id || m.awayTeam === team.id) &&
    m.status === 'finished'
  );

  const stats = teamMatches.reduce((acc, match) => {
    const isHome = match.homeTeam === team.id;
    const goalsFor = isHome ? match.homeScore! : match.awayScore!;
    const goalsAgainst = isHome ? match.awayScore! : match.homeScore!;
    const won = goalsFor > goalsAgainst;
    const drawn = goalsFor === goalsAgainst;

    return {
      points: acc.points + (won ? 3 : drawn ? 1 : 0),
      played: acc.played + 1,
      won: acc.won + (won ? 1 : 0),
      drawn: acc.drawn + (drawn ? 1 : 0),
      lost: acc.lost + (!won && !drawn ? 1 : 0),
      goalsFor: acc.goalsFor + goalsFor,
      goalsAgainst: acc.goalsAgainst + goalsAgainst,
    };
  }, {
    points: 0,
    played: 0,
    won: 0,
    drawn: 0,
    lost: 0,
    goalsFor: 0,
    goalsAgainst: 0,
  });

  return {
    ...team,
    stats: {
      ...team.stats,
      ...stats,
    },
  } as Team;
}).sort((a, b) => {
  // Ordenar por puntos primero
  const pointsDiff = (b.stats?.points || 0) - (a.stats?.points || 0);
  if (pointsDiff !== 0) return pointsDiff;

  // Si hay empate en puntos, ordenar por diferencia de goles
  const goalDiffB = (b.stats?.goalsFor || 0) - (b.stats?.goalsAgainst || 0);
  const goalDiffA = (a.stats?.goalsFor || 0) - (a.stats?.goalsAgainst || 0);
  return goalDiffB - goalDiffA;
}).slice(0, 6);

---
<Layout title="Liga de Fútbol">
	<main>
		<Hero />

		<MatchesSection
			lastMatches={lastMatches}
			nextMatches={nextMatches}
			sortedTeams={sortedTeams}
			getTeamById={getTeamById}
			getTeamName={getTeamName}
		/>

		<!-- Secciones Preview -->
		<div class="container mx-auto px-4 py-16">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<!-- Estadísticas -->
				<div class="bg-white rounded-lg shadow-md overflow-hidden flex flex-col">
					<div class="p-6 flex-1">
						<h2 class="text-2xl font-bold text-gray-900 mb-4">Goleadores</h2>
						<div class="space-y-4">
							{topScorers.map((scorer, index) => (
								<div class="flex items-center justify-between">
									<div class="flex items-center">
										<span class="text-2xl font-bold text-blue-600 mr-4">#{index + 1}</span>
										<div>
											<p class="font-medium">{scorer.name}</p>
											<p class="text-sm text-gray-500">{scorer.team}</p>
										</div>
									</div>
									<div class="text-lg font-semibold">{scorer.goals} goles</div>
								</div>
							))}
						</div>
					</div>
					<div class="p-4 bg-gray-50 border-t border-gray-100">
						<a
							href="/estadisticas"
							class="inline-block w-full text-center bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors"
						>
							Ver todas las estadísticas
						</a>
					</div>
				</div>

				<!-- Patrocinadores -->
				<div class="bg-white rounded-lg shadow-md overflow-hidden flex flex-col">
					<div class="p-6 flex-1">
						<h2 class="text-2xl font-bold text-gray-900 mb-4">Patrocinadores</h2>
						<div class="grid grid-cols-2 gap-4">
							{mainSponsors.map((sponsor) => (
								<div class="text-center">
									<img
										src={sponsor.logo}
										alt={sponsor.name}
										class="h-20 w-auto mx-auto mb-2 grayscale hover:grayscale-0 transition-all"
									/>
									<p class="text-sm font-medium">{sponsor.name}</p>
								</div>
							))}
						</div>
					</div>
					<div class="p-4 bg-gray-50 border-t border-gray-100">
						<a
							href="/patrocinadores"
							class="inline-block w-full text-center bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition-colors"
						>
							Ver todos los patrocinadores
						</a>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
