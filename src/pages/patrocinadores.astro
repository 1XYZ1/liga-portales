---
import Layout from '../layouts/Layout.astro';
import { sponsors } from '../../data/sponsors';

const tierOrder = {
  platinum: 1,
  gold: 2,
  silver: 3,
  bronze: 4
};

const sortedSponsors = sponsors.sort((a, b) => tierOrder[a.tier] - tierOrder[b.tier]);
---

<Layout title="Patrocinadores - Liga de Fútbol">
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-8">Nuestros Patrocinadores</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedSponsors.map((sponsor) => (
        <div class={`bg-white rounded-lg shadow-md overflow-hidden transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1 ${
          sponsor.tier === 'platinum' ? 'lg:col-span-3 md:col-span-2' :
          sponsor.tier === 'gold' ? 'lg:col-span-2 md:col-span-2' : ''
        }`}>
          <div class="relative">
            <div class="absolute top-0 right-0 px-3 py-1 m-2 text-sm rounded-full
              ${sponsor.tier === 'platinum' ? 'bg-purple-100 text-purple-800' :
                sponsor.tier === 'gold' ? 'bg-yellow-100 text-yellow-800' :
                'bg-gray-100 text-gray-800'}">
              {sponsor.tier.charAt(0).toUpperCase() + sponsor.tier.slice(1)}
            </div>
            <div class="p-6">
              <div class="flex items-center justify-center h-32 mb-4">
                <img
                  src={sponsor.logo}
                  alt={`Logo de ${sponsor.name}`}
                  class="max-h-full max-w-full object-contain"
                />
              </div>
              <div class="text-center">
                <h2 class="text-xl font-semibold text-gray-900 mb-2">{sponsor.name}</h2>
                <p class="text-gray-600 mb-4">{sponsor.description}</p>
                <a
                  href={sponsor.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center text-blue-600 hover:text-blue-800"
                >
                  Visitar sitio web
                  <svg
                    class="w-4 h-4 ml-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>
</Layout>

<style>
  img {
    filter: grayscale(100%);
    transition: filter 0.3s ease-in-out;
  }

  img:hover {
    filter: grayscale(0%);
  }
</style>