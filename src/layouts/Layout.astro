---
import Navigation from '../components/Navigation';
import { siteConfig } from '../config/site';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: string;
}

const {
	title = siteConfig.name,
	description = siteConfig.description,
	image = siteConfig.ogImage,
	type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteConfig.url);
const socialImageURL = new URL(image, siteConfig.url);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		{/* SEO */}
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={siteConfig.keywords.join(", ")} />
		<link rel="canonical" href={canonicalURL} />

		{/* Favicon */}
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#1d4ed8" />

		{/* Open Graph / Facebook */}
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />
		<meta property="og:image:alt" content={`${title} | ${siteConfig.name}`} />

		{/* Twitter */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageURL} />
		<meta name="twitter:image:alt" content={`${title} | ${siteConfig.name}`} />

		{/* Verificación de sitio */}
		<meta name="google-site-verification" content="tu-código-de-verificación" />

		{/* Otros */}
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="index, follow" />
		<meta name="format-detection" content="telephone=no" />

		{/* PWA */}
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content={siteConfig.name} />
	</head>
	<body class="min-h-screen bg-gray-50">
		<header class="bg-white shadow-sm sticky top-0 z-50">
			<div class="container mx-auto px-4">
				<div class="flex justify-between items-center h-20 md:h-24">
					<div class="flex items-center flex-shrink-0">
						<a href="/" class="flex items-center gap-3 min-w-0">
							<div class="w-16 h-16 md:w-16 md:h-16 flex-shrink-0">
								<img
									src="/images/logo-portales.jpg"
									alt={`Logo ${siteConfig.name}`}
									class="w-full h-full object-contain"
									width="80"
									height="80"
								/>
							</div>
							<span class="text-xl md:text-3xl font-bold text-gray-900 truncate">{siteConfig.name}</span>
						</a>
					</div>
					<Navigation client:load />
				</div>
			</div>
		</header>

		<slot />

		<footer class="bg-white border-t mt-12">
			<div class="container mx-auto px-4 py-8">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div>
						<h3 class="text-sm font-semibold text-gray-900 tracking-wider uppercase mb-4">
							Sobre Nosotros
						</h3>
						<p class="text-base text-gray-600">
							{siteConfig.description}
						</p>
					</div>
					<div>
						<h3 class="text-sm font-semibold text-gray-900 tracking-wider uppercase mb-4">
							Enlaces Rápidos
						</h3>
						<ul class="space-y-2">
							<li>
								<a href="/equipos" class="text-base text-gray-600 hover:text-gray-900">
									Equipos
								</a>
							</li>
							<li>
								<a href="/calendario" class="text-base text-gray-600 hover:text-gray-900">
									Calendario
								</a>
							</li>
							<li>
								<a href="/tabla" class="text-base text-gray-600 hover:text-gray-900">
									Tabla de Posiciones
								</a>
							</li>
						</ul>
					</div>
					<div>
						<h3 class="text-sm font-semibold text-gray-900 tracking-wider uppercase mb-4">
							Recursos
						</h3>
						<ul class="space-y-2">
							<li>
								<a href="/reglamento" class="text-base text-gray-600 hover:text-gray-900">
									Reglamento
								</a>
							</li>
							<li>
								<a href="/faq" class="text-base text-gray-600 hover:text-gray-900">
									Preguntas Frecuentes
								</a>
							</li>
						</ul>
					</div>
					<div>
						<h3 class="text-sm font-semibold text-gray-900 tracking-wider uppercase mb-4">
							Contacto
						</h3>
						<ul class="space-y-2">
							<li class="text-base text-gray-600">
								<span class="font-medium">Email:</span> {siteConfig.contact.email}
							</li>
							<li class="text-base text-gray-600">
								<span class="font-medium">Teléfono:</span> {siteConfig.contact.phone}
							</li>
						</ul>
						<div class="mt-4 flex gap-4">
							<a
								href={siteConfig.links.instagram}
								target="_blank"
								rel="noopener noreferrer"
								class="text-gray-600 hover:text-gray-900"
							>
								<span class="sr-only">Instagram</span>
								<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
									<path
										fill-rule="evenodd"
										d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"
										clip-rule="evenodd"
									/>
								</svg>
							</a>
							<a
								href={siteConfig.links.whatsapp}
								target="_blank"
								rel="noopener noreferrer"
								class="text-gray-600 hover:text-gray-900"
							>
								<span class="sr-only">WhatsApp</span>
								<svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
									<path
										fill-rule="evenodd"
										d="M20.472 3.528C18.208 1.264 15.136 0 11.888 0 5.392 0 0.112 5.28 0.112 11.776c0 2.08.544 4.096 1.568 5.872L0 24l6.496-1.696c1.712.928 3.648 1.44 5.6 1.44h.016c6.496 0 11.776-5.28 11.776-11.776 0-3.152-1.232-6.112-3.416-8.44zM11.888 21.616h-.016c-1.76 0-3.488-.464-4.992-1.344l-.352-.208-3.712.976.992-3.632-.24-.368c-.96-1.536-1.472-3.328-1.472-5.168 0-5.392 4.384-9.776 9.792-9.776 2.608 0 5.056 1.024 6.896 2.864 1.84 1.84 2.864 4.288 2.864 6.896 0 5.408-4.384 9.76-9.76 9.76zm5.376-7.312c-.288-.144-1.728-.848-1.984-.944-.272-.096-.464-.144-.656.144-.192.288-.752.944-.928 1.136-.176.192-.352.208-.64.064-.288-.144-1.216-.448-2.32-1.424-.864-.768-1.44-1.712-1.616-2-.176-.288-.016-.448.128-.592.144-.144.32-.368.48-.56.144-.192.192-.336.304-.56.096-.224.048-.416-.048-.576-.096-.144-.656-1.584-.896-2.176-.24-.576-.48-.496-.656-.496-.176 0-.368-.016-.56-.016-.192 0-.512.064-.784.352-.272.288-1.04 1.008-1.04 2.448 0 1.44 1.056 2.832 1.2 3.024.144.192 2.032 3.088 4.912 4.32.688.288 1.216.464 1.632.592.688.224 1.312.192 1.808.112.544-.08 1.728-.704 1.984-1.376.24-.672.24-1.248.176-1.376-.064-.144-.24-.224-.528-.368z"
										clip-rule="evenodd"
									/>
								</svg>
							</a>
						</div>
					</div>
				</div>
				<div class="mt-8 border-t border-gray-200 pt-8 text-center">
					<p class="text-base text-gray-600">
						&copy; {new Date().getFullYear()} {siteConfig.name}. Todos los derechos reservados.
					</p>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
